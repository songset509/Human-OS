# Supabase (required in production / Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# OpenAI (optional — coach/mentors use fallbacks without this)
OPENAI_API_KEY=your_openai_api_key

# App URL (required for auth email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local only: set to false to disable demo mode when Supabase is missing
# HUMANOS_ALLOW_DEMO=true

# Optional: service role for admin scripts only — NEVER expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
